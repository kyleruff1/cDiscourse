# Template for bot fixture runner credentials.
# Copy this file to `.env.bot-tests` (gitignored) and fill in test-only values.
# DO NOT commit `.env.bot-tests`.
# DO NOT use production credentials.
# DO NOT use a service-role key here — the runner uses normal Supabase auth only.

# Supabase project URL + publishable (anon) key (same as in .env).
# The runner reads .env too; these are only needed here if you want to run
# the bot script without .env present.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Admin human account used to create/verify bot users via admin-users.
CDISCOURSE_ADMIN_EMAIL=
CDISCOURSE_ADMIN_PASSWORD=

# Bot test accounts — use plus-addressed emails and generated passwords.
CDISCOURSE_BOT_A_EMAIL=
CDISCOURSE_BOT_A_PASSWORD=
CDISCOURSE_BOT_A_LABEL=bot-alpha
CDISCOURSE_BOT_A_PERSONA=calm

CDISCOURSE_BOT_B_EMAIL=
CDISCOURSE_BOT_B_PASSWORD=
CDISCOURSE_BOT_B_LABEL=bot-beta
CDISCOURSE_BOT_B_PERSONA=skeptical

CDISCOURSE_BOT_C_EMAIL=
CDISCOURSE_BOT_C_PASSWORD=
CDISCOURSE_BOT_C_LABEL=bot-gamma
CDISCOURSE_BOT_C_PERSONA=conciliatory

# Which fixture scenario to run (file under fixtures/argument-scenarios/).
CDISCOURSE_FIXTURE_SCENARIO=sports-play-in

# ── ARG-ROOM-007 live-smoke matrix (operator-armed) ──
# Two OPTIONAL extra accounts (D + E) so the public cap-5 fill checks (#5/#7)
# have >= 6 distinct JWT logins. These are ordinary user logins — NO service-role.
# Leave blank to run the test-covered fallback (the harness emits
# accounts_insufficient → covered_by:[002-B6, roomCapacityModel-parity], never a
# misleading PASS). Reuse the kyleruff+devtestNN@gmail.com seed shape if preferred.
CDISCOURSE_BOT_D_EMAIL=
CDISCOURSE_BOT_D_PASSWORD=
CDISCOURSE_BOT_E_EMAIL=
CDISCOURSE_BOT_E_PASSWORD=

# Arm flag for the ARG-ROOM-007 live-smoke harness. The harness is DRY-RUN by
# default and refuses live execution unless BOTH this is set to 1 AND `--live`
# is passed on the CLI. It NEVER self-arms; it NEVER sets INVITE_EMAIL_ENABLED
# or the new-user auth-bridge gate (those are operator-armed on the deployed
# function). Unset after the run (disarm).
CDISCOURSE_ALLOW_ARG_ROOM_LIVE_SMOKE=
