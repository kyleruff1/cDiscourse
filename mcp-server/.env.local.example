# MCP-SERVER-001 — local development environment template.
# Copy to .env.local (gitignored) and edit before running `deno task dev`.

# Bearer token the server expects on every /mcp + /mcp/adapter-compat request.
# Use a long random string for local dev; production rotates this value.
MCP_SERVER_BEARER_TOKEN=local-dev-bearer-do-not-use-in-prod

# Model provider — only `anthropic` is supported in v1.
MODEL_PROVIDER=anthropic

# Anthropic API key — used ONLY by the server, never by CDiscourse client/app.
# Leave blank if running the smoke with MCP_SERVER_USE_FIXTURE_PROVIDER=true.
ANTHROPIC_API_KEY=

# Optional override; defaults to `claude-haiku-4-5` (alias). Pin to a dated
# snapshot for production (e.g. `claude-haiku-4-5-20251001`) when desired.
# ANTHROPIC_MODEL=claude-haiku-4-5

# Environment label echoed by /health. One of: local | dev | staging | prod.
MCP_SERVER_ENV=local

# Port the server binds. Defaults to 8080 if unset.
MCP_SERVER_PORT=8080

# Timeouts (ms). Defaults shown.
# MCP_SERVER_REQUEST_TIMEOUT_MS=30000
# MCP_SERVER_MODEL_TIMEOUT_MS=25000

# Comma-separated allowed Origin values. Empty/unset = allow all. Recommended
# to pin to your Supabase project URL in production.
# MCP_SERVER_ALLOWED_ORIGINS=

# Fixture-provider mode. When `true`, the server bypasses the real Anthropic
# call and returns the canned fixture from fixtures/classify-semantic-move.response.json.
# Use ONLY for local smoke and CI; NEVER in production.
MCP_SERVER_USE_FIXTURE_PROVIDER=true
