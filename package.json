{
  "name": "cdiscourse",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "test": "jest --passWithNoTests",
    "checkpoint": "node scripts/checkpoint-status.mjs",
    "bot:fixture": "node scripts/bot-fixtures/runScenario.js",
    "bot:fixture:sports": "node scripts/bot-fixtures/runScenario.js sports-play-in",
    "bot:fixture:popculture": "node scripts/bot-fixtures/runScenario.js pop-culture-trailers",
    "bot:fixture:bikelanes": "node scripts/bot-fixtures/runScenario.js light-civic-bike-lanes",
    "bot:fixture:remotework": "node scripts/bot-fixtures/runScenario.js everyday-remote-work",
    "bot:fixture:generate-stress": "node scripts/bot-fixtures/generateStressScenarios.js --count 50",
    "bot:fixture:stress:dry": "node scripts/bot-fixtures/runStressBatch.js --dry --regenerate --count 10",
    "bot:fixture:stress:10": "node scripts/bot-fixtures/runStressBatch.js --regenerate --count 10",
    "bot:fixture:stress:50": "node scripts/bot-fixtures/runStressBatch.js --regenerate --count 50",
    "bot:fixture:corpus:dry": "node scripts/bot-fixtures/runStressBatch.js --dry --corpus --regenerate --count 10",
    "bot:fixture:corpus:10": "node scripts/bot-fixtures/runStressBatch.js --corpus --regenerate --count 10",
    "bot:fixture:corpus:50": "node scripts/bot-fixtures/runStressBatch.js --corpus --regenerate --count 50",
    "engagement:intel:plan": "node scripts/engagement-intelligence/xNewsPlan.js",
    "engagement:intel:synthetic": "node scripts/engagement-intelligence/analyzeEngagementSamples.js --synthetic",
    "engagement:intel:x-news:dry": "node scripts/engagement-intelligence/xNewsCollect.js --dry",
    "engagement:intel:x-news:pilot": "node scripts/engagement-intelligence/xNewsCollect.js --pilot",
    "engagement:intel:replies:pilot": "node scripts/engagement-intelligence/xReplyCollect.js --pilot",
    "engagement:intel:xai:classify": "node scripts/engagement-intelligence/xaiClassifyPairs.js",
    "engagement:intel:xai:probe:dry": "node scripts/engagement-intelligence/xaiAuthProbe.js",
    "engagement:intel:xai:probe:live": "node scripts/engagement-intelligence/xaiAuthProbe.js --probe-live",
    "engagement:intel:xai:probe:no-key": "node scripts/engagement-intelligence/xaiAuthProbe.js --probe-live --probe-missing-key",
    "engagement:intel:x-news:tiny-pilot": "node scripts/engagement-intelligence/runTinyXNewsPilot.js",
    "bot:fixture:ai:dry": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3",
    "bot:fixture:ai:3": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3 --pilot",
    "bot:fixture:ai:50": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 50 --pilot",
    "bot:fixture:ai:annotated:dry": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3 --annotate",
    "bot:fixture:ai:3:annotated": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3 --pilot --annotate --deep",
    "bot:fixture:ai:50:annotated": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 50 --pilot --annotate --deep",
    "bot:fixture:xai-adversarial:dry": "node scripts/bot-fixtures/runXaiAdversarialThreadCorpus.js --dry --rooms 3 --candidate-posts 30 --top-replies 12 --max-depth 5 --source-mode synthetic",
    "bot:fixture:xai-adversarial:3": "node scripts/bot-fixtures/runXaiAdversarialThreadCorpus.js --pilot --rooms 3 --candidate-posts 30 --top-replies 12 --max-depth 5 --source-mode xai_live --provider xai_responses",
    "bot:fixture:xai-adversarial:50": "node scripts/bot-fixtures/runXaiAdversarialThreadCorpus.js --pilot --rooms 50 --candidate-posts 300 --top-replies 12 --max-depth 10 --source-mode xai_live --provider xai_responses --allow-synthetic-rebuttal"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ]
  }
}
