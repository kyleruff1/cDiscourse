{
  "name": "cdiscourse",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "test": "jest --passWithNoTests",
    "checkpoint": "node scripts/checkpoint-status.mjs",
    "web:build": "expo export --platform web --output-dir dist",
    "web:build:dry": "node scripts/build/build-web.mjs --dry",
    "bot:fixture": "node scripts/bot-fixtures/runScenario.js",
    "bot:fixture:sports": "node scripts/bot-fixtures/runScenario.js sports-play-in",
    "bot:fixture:popculture": "node scripts/bot-fixtures/runScenario.js pop-culture-trailers",
    "bot:fixture:bikelanes": "node scripts/bot-fixtures/runScenario.js light-civic-bike-lanes",
    "bot:fixture:remotework": "node scripts/bot-fixtures/runScenario.js everyday-remote-work",
    "bot:fixture:generate-stress": "node scripts/bot-fixtures/generateStressScenarios.js --count 50",
    "bot:fixture:stress:dry": "node scripts/bot-fixtures/runStressBatch.js --dry --regenerate --count 10",
    "bot:fixture:stress:10": "node scripts/bot-fixtures/runStressBatch.js --regenerate --count 10",
    "bot:fixture:stress:50": "node scripts/bot-fixtures/runStressBatch.js --regenerate --count 50",
    "bot:fixture:corpus:dry": "node scripts/bot-fixtures/runStressBatch.js --dry --corpus --regenerate --count 10",
    "bot:fixture:corpus:10": "node scripts/bot-fixtures/runStressBatch.js --corpus --regenerate --count 10",
    "bot:fixture:corpus:50": "node scripts/bot-fixtures/runStressBatch.js --corpus --regenerate --count 50",
    "engagement:intel:plan": "node scripts/engagement-intelligence/xNewsPlan.js",
    "engagement:intel:synthetic": "node scripts/engagement-intelligence/analyzeEngagementSamples.js --synthetic",
    "engagement:intel:x-news:dry": "node scripts/engagement-intelligence/xNewsCollect.js --dry",
    "engagement:intel:x-news:pilot": "node scripts/engagement-intelligence/xNewsCollect.js --pilot",
    "engagement:intel:replies:pilot": "node scripts/engagement-intelligence/xReplyCollect.js --pilot",
    "engagement:intel:xai:classify": "node scripts/engagement-intelligence/xaiClassifyPairs.js",
    "engagement:intel:xai:probe:dry": "node scripts/engagement-intelligence/xaiAuthProbe.js",
    "engagement:intel:xai:probe:live": "node scripts/engagement-intelligence/xaiAuthProbe.js --probe-live",
    "engagement:intel:xai:probe:no-key": "node scripts/engagement-intelligence/xaiAuthProbe.js --probe-live --probe-missing-key",
    "engagement:intel:x-news:tiny-pilot": "node scripts/engagement-intelligence/runTinyXNewsPilot.js",
    "bot:fixture:ai:dry": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3",
    "bot:fixture:ai:3": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3 --pilot",
    "bot:fixture:ai:50": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 50 --pilot",
    "bot:fixture:ai:annotated:dry": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3 --annotate",
    "bot:fixture:ai:3:annotated": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 3 --pilot --annotate --deep",
    "bot:fixture:ai:50:annotated": "node scripts/bot-fixtures/runAiDrivenCorpus.js --rooms 50 --pilot --annotate --deep",
    "bot:fixture:xai-adversarial:dry": "node scripts/bot-fixtures/runXaiAdversarialBotCorpus.js --dry --scenarios 10 --max-depth 6",
    "bot:fixture:xai-adversarial:tiny": "node scripts/bot-fixtures/runXaiAdversarialBotCorpus.js --pilot --scenarios 5 --max-depth 6",
    "bot:fixture:xai-adversarial:50": "node scripts/bot-fixtures/runXaiAdversarialBotCorpus.js --pilot --scenarios 50 --max-depth 10",
    "bot:fixture:xai-thread:dry": "node scripts/bot-fixtures/runXaiAdversarialThreadCorpus.js --dry --rooms 3 --candidate-posts 30 --top-replies 12 --max-depth 5 --source-mode synthetic",
    "bot:fixture:xai-thread:3": "node scripts/bot-fixtures/runXaiAdversarialThreadCorpus.js --pilot --rooms 3 --candidate-posts 30 --top-replies 12 --max-depth 5 --source-mode xai_live --provider xai_responses",
    "skills:validate": "node scripts/skills/validateBotSkills.js",
    "engagement:intel:xai:adversarial:dry": "node scripts/engagement-intelligence/xaiAdversarialSourceHarvest.js --stories 5 --replies 3 --dry",
    "engagement:intel:xai:adversarial:tiny": "node scripts/engagement-intelligence/xaiAdversarialSourceHarvest.js --pilot --stories 5 --replies 5",
    "engagement:intel:xai:adversarial:100": "node scripts/engagement-intelligence/xaiAdversarialSourceHarvest.js --pilot --stories 100 --replies 10",
    "diagnostics:inspect:dry": "node scripts/diagnostics/buildDiagnosticInspectPackage.js --dry",
    "diagnostics:inspect": "node scripts/diagnostics/buildDiagnosticInspectPackage.js",
    "diagnostics:inspect:db": "node scripts/diagnostics/buildDiagnosticInspectPackage.js --include-db",
    "diagnostics:inspect:all": "node scripts/diagnostics/buildDiagnosticInspectPackage.js --include-db --include-all-reports --include-all-jsonl",
    "bot:engage:existing:dry": "node scripts/bot-fixtures/engageExistingRooms.js --dry --target-moves 20 --sample-pct 50",
    "bot:engage:existing:pilot": "node scripts/bot-fixtures/engageExistingRooms.js --pilot --target-moves 20 --sample-pct 50 --max-rooms 50",
    "bot:engage:existing:deep": "node scripts/bot-fixtures/engageExistingRooms.js --pilot --target-moves-min 18 --target-moves-max 25 --sample-pct 60 --max-rooms 60",
    "bot:engage:open:dry": "node scripts/bot-fixtures/runOpenRoomEngagementBots.js --dry --max-rooms 20 --target-min-moves 15 --target-max-moves 25",
    "bot:engage:open:tiny": "node scripts/bot-fixtures/runOpenRoomEngagementBots.js --pilot --max-rooms 10 --target-min-moves 8 --target-max-moves 12 --target-coverage 0.10",
    "github:ux-board:dry": "node scripts/github/syncUxProjectBoard.js --dry-run",
    "github:ux-board:apply": "node scripts/github/syncUxProjectBoard.js --apply",
    "github:agent:queue": "node scripts/github/agentIssueRunner.js queue",
    "github:agent:ledger": "node scripts/github/agentIssueRunner.js ledger",
    "github:agent:claim": "node scripts/github/agentIssueRunner.js claim",
    "github:agent:signoff": "node scripts/github/agentIssueRunner.js signoff"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "serve": "14.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx)"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.claude/worktrees/"
    ]
  }
}
