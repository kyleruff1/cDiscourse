# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local
.env.bot-tests
.env.bot-tests.local
.env.bot-tests.bak-*
.env.bot-tests.bak.*

# Stress-test artifacts (generated fixtures + full local logs)
logs/
logs/bot-stress/
fixtures/generated-scenarios/

# Engagement intelligence (Stage 6.1.3.2) — raw / classified / redacted local-only
.env.engagement-intelligence
.env.engagement-intelligence.*
!.env.engagement-intelligence.example
logs/engagement-intelligence/

# Diagnostic inspect packages (staging folders + ZIPs are local artifacts).
artifacts/diagnostics/
data/engagement-intelligence/raw/
data/engagement-intelligence/redacted/
data/engagement-intelligence/classified/
data/engagement-intelligence/local/

# Claude Code local settings (user-specific permissions)
.claude/settings.local.json

# Claude Code agent worktrees (isolated per-card workspaces created by the
# agent pipeline; local-only, never staged — mirrors SAFE_STAGE_DENYLIST in
# scripts/github/agentIssueRunner.js)
.claude/worktrees/

# typescript
*.tsbuildinfo

# test coverage
coverage/

# Supabase local temp files
supabase/.temp/

# Admin bootstrap scripts with real emails (never commit)
scripts/admin/*.local.sql
scripts/admin/bootstrap-admin.sql

# generated native folders
/ios
/android
