.DS_Store
*.pem

# local env files
.env
.env*.local
.env.bot-tests
.env.bot-tests.local
.env.bot-tests.bak-*
.env.bot-tests.bak.*

# Stress-test artifacts (generated fixtures + full local logs)
logs/
logs/bot-stress/
fixtures/generated-scenarios/

# Engagement intelligence (Stage 6.1.3.2) — raw / classified / redacted local-only
.env.engagement-intelligence
.env.engagement-intelligence.*
!.env.engagement-intelligence.example
logs/engagement-intelligence/

# Diagnostic inspect packages (staging folders + ZIPs are local artifacts).
artifacts/diagnostics/
data/engagement-intelligence/raw/
data/engagement-intelligence/redacted/
data/engagement-intelligence/classified/
data/engagement-intelligence/local/

# Claude Code local settings (user-specific permissions)
.claude/settings.local.json

# Claude Code agent worktrees (isolated per-card workspaces created by the
# agent pipeline; local-only, never staged — mirrors SAFE_STAGE_DENYLIST in
# scripts/github/agentIssueRunner.js)
.claude/worktrees/

# Claude Code local backup snapshots of agent/skill/script bundles
.claude/*.zip

# Local docs / branding archives (operator-created snapshots; local-only).
# Surfaced by POSTRUN-UX001 audit as the "5 uncommitted changes" warning
# emitter on PR creation. The branding zip is a 50KB asset (May 23); docs.zip
# is a 3.4MB operator-created docs snapshot (May 25). Neither belongs in git.
/docs.zip
assets/branding/*.zip

# Bot-fixture dry-run regeneration noise (POST-UX001-noise-resolution).
# These files are deterministic regenerations of tracked 2026-05-23 versions
# (byte-identical: 20979 bytes for ai-driven-bot-corpus-dry, 6163 bytes for
# engagement-epidemiology-synthetic). The operator's selective-commit pattern
# (2026-05-17 through 2026-05-23 are tracked) is preserved via the override:
# to commit a specific dry-run as regression evidence, use `git add -f
# docs/testing-runs/<date>-<kind>.md`. Tracked versions are unaffected by
# gitignore; only new regenerations are silenced.
docs/testing-runs/*-ai-driven-bot-corpus-dry.md
docs/testing-runs/*-engagement-epidemiology-synthetic.md

# typescript
*.tsbuildinfo

# test coverage
coverage/

# Supabase local temp files
supabase/.temp/

# Admin bootstrap scripts with real emails (never commit)
scripts/admin/*.local.sql
scripts/admin/bootstrap-admin.sql

# generated native folders
/ios
/android
.scratch/
